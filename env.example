# HiveChat 环境配置示例
# 复制此文件为 .env 并修改相应的配置值

# ===================
# 基础配置
# ===================
HOST_PORT=3000
DATA_PATH=./data
TZ=Asia/Shanghai

# ===================
# LinuxServer 权限配置
# ===================
PUID=1000
PGID=10

# ===================
# 数据库配置
# ===================
DB_PASSWORD=your_secure_password_here

# ===================
# 认证配置
# ===================
AUTH_SECRET=your_auth_secret_here_at_least_32_characters
ADMIN_CODE=11223344
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ===================
# 邮件认证配置
# ===================
EMAIL_AUTH_STATUS=ON

# ===================
# 飞书认证配置
# ===================
FEISHU_AUTH_STATUS=OFF
FEISHU_CLIENT_ID=
FEISHU_CLIENT_SECRET=

# ===================
# 企业微信认证配置
# ===================
WECOM_AUTH_STATUS=OFF
WECOM_CLIENT_ID=
WECOM_AGENT_ID=
WECOM_CLIENT_SECRET=

# ===================
# 钉钉认证配置
# ===================
DINGDING_AUTH_STATUS=OFF
DINGDING_CLIENT_ID=
DINGDING_CLIENT_SECRET=

# ===================
# 代理配置
# ===================
# HTTPS代理设置（可选）
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=

# ===================
# AI模型API配置
# ===================
# OpenAI配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude配置
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Gemini配置
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ===================
# 其他配置
# ===================
# 日志级别
LOG_LEVEL=info

# 最大上传文件大小
MAX_UPLOAD_SIZE=10MB
